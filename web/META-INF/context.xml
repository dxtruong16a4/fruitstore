<?xml version="1.0" encoding="UTF-8"?>
<Context path="/FruitStore">
    <!-- Database Connection Pool -->
    <Resource name="jdbc/fruitstore" 
              auth="Container"
              type="javax.sql.DataSource"
              maxTotal="100" 
              maxIdle="30"
              maxWaitMillis="10000"
              username="root" 
              password="password"
              driverClassName="com.mysql.cj.jdbc.Driver"
              url="jdbc:mysql://localhost:3306/fruitstore?useSSL=false&amp;serverTimezone=UTC"/>
</Context>
